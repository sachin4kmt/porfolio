<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= data.name %> | Flutter Architect</title>
    
    <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/gsap.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/ScrollTrigger.min.js"></script>
    <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;700&family=Plus+Jakarta+Sans:wght@400;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    
    <style>
        :root {
            --flutter-blue: #02569B;
            --flutter-cyan: #01C8FF;
            --bg: #040d16;
            --card-bg: rgba(255, 255, 255, 0.03);
        }

        * { margin: 0; padding: 0; box-sizing: border-box; }
        body { background-color: var(--bg); color: white; font-family: 'Plus Jakarta Sans', sans-serif; overflow-x: hidden; }

        body::before {
            content: ''; position: fixed; top: -10%; left: -10%; width: 40%; height: 40%;
            background: radial-gradient(circle, rgba(1, 200, 255, 0.1) 0%, transparent 70%); z-index: -1;
        }

        .container { max-width: 1200px; margin: 0 auto; padding: 0 40px; }

        /* Mockup Styles */
        .phone-mockup { width: 220px; height: 440px; background: #111; border: 8px solid #222; border-radius: 35px; flex-shrink: 0; position: relative; overflow: hidden; display: flex; align-items: center; justify-content: center; box-shadow: 0 20px 40px rgba(0,0,0,0.5); }
        .phone-mockup::after { content: ''; position: absolute; top: 10px; width: 50px; height: 18px; background: #222; border-radius: 20px; z-index: 10; }
        
        .mockup-content { width: 100%; height: 100%; background: linear-gradient(180deg, #1a1a1a 0%, #080808 100%); display: flex; align-items: center; justify-content: center; }
        .app-logo-inside { width: 80px; height: 80px; border-radius: 20px; object-fit: cover; box-shadow: 0 10px 20px rgba(0,0,0,0.4); border: 1px solid rgba(255,255,255,0.1); }

        /* Screenshot Gallery */
        .screenshot-gallery {
    display: flex;
    gap: 12px;
    overflow-x: auto;
    margin: 20px 0;
    padding-bottom: 10px;
    width: 100%; /* Card ki width ke andar rahega */
    max-width: calc(100vw - 120px); /* Mobile safety */
    scrollbar-width: thin;
    scrollbar-color: var(--flutter-cyan) transparent;
}
        .screenshot-gallery::-webkit-scrollbar { height: 4px; }
        .screenshot-gallery::-webkit-scrollbar-thumb { background: var(--flutter-cyan); border-radius: 10px; }
        .ss-img { height: 180px; border-radius: 10px; border: 1px solid rgba(255,255,255,0.1); }

        /* Typography & Layout */
        .hero { height: 100vh; display: flex; flex-direction: column; justify-content: center; }
        .widget-label { font-family: 'JetBrains Mono', monospace; color: var(--flutter-cyan); font-size: 0.85rem; margin-bottom: 8px; }
        .company-link { text-decoration: none; color: var(--flutter-cyan); font-weight: bold; font-size: 0.9rem; }
        .company-link:hover { text-decoration: underline; }

        h1 { font-size: clamp(3rem, 10vw, 7rem); font-weight: 800; line-height: 0.9; background: linear-gradient(to bottom right, #fff 50%, var(--flutter-cyan)); -webkit-background-clip: text; -webkit-text-fill-color: transparent; }
        .section-title { font-size: 2.5rem; margin: 100px 0 50px; display: flex; align-items: center; gap: 20px; }
        
        .project-card { background: var(--card-bg); border: 1px solid rgba(255, 255, 255, 0.1); border-radius: 40px; padding: 50px; display: flex; gap: 50px; margin-bottom: 50px; backdrop-filter: blur(20px); transition: 0.4s; }
        .project-card:hover { border-color: var(--flutter-cyan); transform: translateY(-10px); }
.title-row {
    display: flex;
    align-items: center;
    gap: 15px;
    margin-top: 10px;
    flex-wrap: wrap; /* Lambe titles ke liye safety */
}
.project-info {
    flex: 1;
    min-width: 0; /* Isse flex child overflow nahi karega */
}
        .app-links { display: flex; gap: 12px; margin-top: 30px; flex-wrap: wrap; }
        .app-btn { text-decoration: none; color: white; background: rgba(255, 255, 255, 0.05); border: 1px solid rgba(255, 255, 255, 0.1); padding: 10px 20px; border-radius: 14px; font-size: 0.85rem; display: flex; align-items: center; gap: 8px; transition: 0.3s; }
        .app-btn:hover { background: var(--flutter-cyan); color: #000; border-color: var(--flutter-cyan); }
        .btn-web { border-color: var(--flutter-cyan); color: var(--flutter-cyan); }

        .skills-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(160px, 1fr)); gap: 20px; }
        .skill-item { background: var(--card-bg); padding: 25px; border-radius: 24px; text-align: center; border: 1px solid transparent; transition: 0.3s; }
        .skill-item:hover { border-color: var(--flutter-cyan); background: rgba(1, 200, 255, 0.05); }

        .reveal { opacity: 0; transform: translateY(30px); }
        @media (max-width: 900px) { .project-card { flex-direction: column; align-items: center; text-align: center; } .app-links { justify-content: center; } .screenshot-gallery { justify-content: center; } }
    </style>
</head>
<body>

    <div class="container">
        <!-- HERO -->
        <section class="hero">
            <p class="widget-label">STATED_WIDGET()</p>
            <h1>BUILDING<br>SEAMLESS<br><span style="color: var(--flutter-cyan);">EXPERIENCES</span></h1>
            <p style="margin-top: 30px; opacity: 0.6; max-width: 600px; line-height: 1.6;">
                <%= data.summary %>
            </p>
        </section>

      <!-- PROJECTS SECTION -->
<section>
    <h2 class="section-title"><span style="color: var(--flutter-cyan);">01.</span> APPS_BUILT</h2>
    
    <% data.projects.forEach(function(p, i) { 
        const company = data.experience.find(e => e.id === p.companyId);
        const hasScreenshots = p.screenshots && p.screenshots.length > 0;
    %>
        <div class="project-card reveal">
            <!-- Dynamic Phone Mockup -->
            <div class="phone-mockup">
                <div class="mockup-content">
                    <% if(hasScreenshots) { %>
                        <img src="<%= p.screenshots[0] %>" style="width: 100%; height: 100%; object-fit: cover;" alt="preview">
                    <% } else if(p.logo) { %>
                        <img src="<%= p.logo %>" class="app-logo-inside" alt="app-logo">
                    <% } else { %>
                        <div style="width: 80px; height: 80px; background: #333; border-radius: 20px;"></div>
                    <% } %>
                </div>
            </div>

            <div class="project-info">
                <!-- Company Link -->
                <% if(company) { %>
                    <p class="widget-label">
                        <a href="<%= company.website %>" target="_blank" class="company-link">
                            <i class="fas fa-link"></i> <%= company.company %>
                        </a>
                        <span style="opacity: 0.5; margin-left: 10px;">/ <%= p.tag %></span>
                    </p>
                <% } %>

                <!-- App Name with Logo Prefix -->
                <div class="title-row">
                    <% if(p.logo) { %>
                        <img src="<%= p.logo %>" style="width: 50px; height: 50px; border-radius: 12px; border: 1px solid rgba(255,255,255,0.1); object-fit: cover;" alt="logo">
                    <% } %>
                    <h3 style="font-size: clamp(1.5rem, 4vw, 2.8rem); line-height: 1.2;"><%= p.title %></h3>
                </div>

                <p style="color: #aaa; line-height: 1.7; margin: 15px 0; white-space: pre-line;">
    <%= p.description %>
</p>
                
                <!-- Tech Chips -->
                <div style="display: flex; gap: 8px; flex-wrap: wrap; margin-bottom: 20px;">
                    <% if(p.tech) { p.tech.forEach(function(t) { %>
                        <span style="background: rgba(255,255,255,0.05); padding: 5px 14px; border-radius: 50px; font-size: 0.75rem; border: 1px solid rgba(255,255,255,0.1);"><%= t %></span>
                    <% }); } %>
                </div>

                <!-- Screenshots Gallery (Restrained inside card) -->
                <% if(hasScreenshots) { %>
                    <div class="screenshot-gallery">
                        <% p.screenshots.forEach(function(ss) { %>
                            <img src="<%= ss %>" class="ss-img" alt="screenshot">
                        <% }); %>
                    </div>
                <% } %>

                <!-- Action Buttons -->
                <div class="app-links">
                    <% if(p.website && p.website !== "#") { %>
                        <a href="<%= p.website %>" target="_blank" class="app-btn btn-web">
                            <i class="fas fa-globe"></i> Website
                        </a>
                    <% } %>
                    <% if(p.android_link && p.android_link !== "#") { %>
                        <a href="<%= p.android_link %>" target="_blank" class="app-btn">
                            <i class="fab fa-android"></i> Play Store
                        </a>
                    <% } %>
                    <% if(p.ios_link && p.ios_link !== "#") { %>
                        <a href="<%= p.ios_link %>" target="_blank" class="app-btn">
                            <i class="fab fa-apple"></i> App Store
                        </a>
                    <% } %>
                </div>
            </div>
        </div>
    <% }); %>
</section>

        <!-- SKILLS -->
        <section style="margin-bottom: 100px;">
            <h2 class="section-title"><span style="color: var(--flutter-cyan);">02.</span> CORE_ENGINE</h2>
            <div class="skills-grid">
                <% data.skills.forEach(function(skill) { %>
                    <div class="skill-item reveal">
                        <div style="width: 40px; height: 40px; background: var(--flutter-cyan); margin: 0 auto 15px; clip-path: polygon(50% 0%, 100% 25%, 100% 75%, 50% 100%, 0% 75%, 0% 25%);"></div>
                        <p style="font-weight: bold;"><%= skill.name %></p>
                        <p style="color: var(--flutter-cyan); font-size: 0.8rem; margin-top: 5px;"><%= skill.level %></p>
                    </div>
                <% }); %>
            </div>
        </section>

        <!-- CAREER LOG -->
        <section style="margin-bottom: 100px;">
            <h2 class="section-title"><span style="color: var(--flutter-cyan);">03.</span> CAREER_LOG()</h2>
            <div style="display: flex; flex-direction: column; gap: 20px;">
                <% data.experience.forEach(function(exp) { %>
                    <div class="project-card reveal" style="padding: 35px; display: block;">
                        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 15px;">
                            <a href="<%= exp.website %>" target="_blank" class="company-link" style="font-size: 1.6rem;">
                                <%= exp.company %>
                            </a>
                            <span style="font-family: 'JetBrains Mono'; opacity: 0.6;"><%= exp.duration %></span>
                        </div>
                        <p style="font-weight: 800; margin-bottom: 8px; color: #fff;"><%= exp.role %></p>
                        <p style="color: #aaa; font-size: 0.9rem; line-height: 1.6;"><%= exp.details %></p>
                    </div>
                <% }); %>
            </div>
        </section>

        <!-- FOOTER -->
        <footer style="padding: 100px 0; text-align: center; border-top: 1px solid rgba(255,255,255,0.1);">
            <p class="widget-label">RETURN_CONTACT()</p>
            <h2 style="font-size: clamp(1.5rem, 5vw, 3rem); margin-bottom: 20px;"><%= data.email %></h2>
            <p style="opacity: 0.4; font-size: 0.8rem;">© 2026 Crafted with Flutter Vibes & Node.js • Jaipur, India</p>
        </footer>
    </div>

    <script>
        gsap.registerPlugin(ScrollTrigger);
        gsap.utils.toArray(".reveal").forEach((elem) => {
            gsap.to(elem, {
                scrollTrigger: { trigger: elem, start: "top 85%", toggleActions: "play none none none" },
                opacity: 1, y: 0, duration: 1, ease: "power3.out"
            });
        });
        gsap.from("h1", { duration: 1.5, y: 50, opacity: 0, stagger: 0.2, ease: "expo.out" });
    </script>
</body>
</html>