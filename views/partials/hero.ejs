/* PRINT SETTINGS */
@media print {
    html, body {
        background-color: #040d16 !important; /* Tera original dark bg */
        color: white !important;
        -webkit-print-color-adjust: exact !important; /* Chrome/Safari fix */
        print-color-adjust: exact !important;
        margin: 0;
        padding: 0;
    }

    /* 2. SHOW EVERYTHING (GSAP Fix) */
    .reveal, .hero-content, .hero-summary, .hero-meta, 
    .project-card, .full-desc, .desc-full, .details-content {
        display: block !important;
        opacity: 1 !important;
        visibility: visible !important;
        max-height: none !important;
        transform: none !important;
    }

    /* 3. TEXT COLORS (Dark Mode in PDF) */
    h1, h2, h3, .widget-label {
        color: var(--flutter-cyan) !important;
        -webkit-print-color-adjust: exact !important;
    }

    .gradient-text {
        background: none !important;
        color: var(--flutter-cyan) !important;
        -webkit-text-fill-color: var(--flutter-cyan) !important;
    }

    p, span, li, code {
        color: rgba(255, 255, 255, 0.8) !important;
    }

    /* 4. CARDS & SECTIONS */
    .project-card, .edu-card {
        background: rgba(255, 255, 255, 0.05) !important;
        border: 1px solid rgba(255, 255, 255, 0.1) !important;
        page-break-inside: avoid;
        margin-bottom: 20px !important;
    }

    /* 5. HIDE UI ELEMENTS */
    nav, .hero-btns, .hero-glow, .phone-nav-btn, .read-more-btn, .dots, footer {
        display: none !important;
    }

    /* 6. SCREENSHOTS GRID */
    .screenshot-gallery {
        display: grid !important;
        grid-template-columns: repeat(5, 1fr) !important;
        gap: 8px !important;
        overflow: visible !important;
    }

    .ss-img {
        border: 1px solid rgba(255, 255, 255, 0.2) !important;
    }
    
}
</style>

<!-- 3. JAVASCRIPT (Logic) -->
<script>
async function sharePortfolio() {
    const shareData = {
        title: '<%= data.name %> | Portfolio',
        text: '<%= data.summary %>',
        url: window.location.href
    };

    try {
        if (navigator.share) {
            await navigator.share(shareData);
        } else {
            const tempInput = document.createElement("input");
            tempInput.value = window.location.href;
            document.body.appendChild(tempInput);
            tempInput.select();
            document.execCommand("copy");
            document.body.removeChild(tempInput);
            alert("Portfolio link copied to clipboard!");
        }
    } catch (err) {
        console.error("Error sharing:", err);
    }
}
</script>


