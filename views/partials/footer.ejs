<footer style="padding: clamp(40px, 8vw, 80px) 0; text-align: center; border-top: 1px solid rgba(255,255,255,0.08); width: 100%; box-sizing: border-box; overflow: hidden;">
    <p class="widget-label" style="letter-spacing: 2px; font-size: 0.8rem; margin-bottom: 12px; font-family: 'JetBrains Mono', monospace; color: var(--flutter-cyan); text-transform: uppercase;">
        RETURN_CONTACT
    </p>
    
    <h2 style="font-size: clamp(1.3rem, 4.5vw, 2.5rem); margin: 0 0 20px 0; font-weight: 800; color: #fff; word-wrap: break-word; overflow-wrap: break-word; word-break: break-all; padding: 0 10px;">
        <%= data.email %>
    </h2>
    
    <p style="opacity: 0.4; font-size: 0.8rem; font-family: 'Space Mono', monospace; margin: 0;">
        &copy; 2026 Sachin Kumawat. All Rights Reserved.
    </p>
</footer>

<style>
    /* Small screen viewport adjustments to maintain elegant balance */
    @media (max-width: 480px) {
        footer {
            padding: 40px 0 !important;
        }
        footer h2 {
            word-break: break-word !important; /* Elegant fallback wrap instead of hard splitting */
        }
    }
</style>