<style>
    :root {
        /* Premium Fluid Flutter Palette Matrix */
        --flutter-blue: #02569B;
        --flutter-cyan: #01C8FF;
        --flutter-sky: #40D1FB; /* Sky fallback patch matched */
        --bg-dark: #050a0f;     /* Linked to match your dark background */
        --bg-card: rgba(255, 255, 255, 0.02); /* Universal consistent token sync */
        --glass-border: rgba(255, 255, 255, 0.08);
        --white: #ffffff;       /* Consistent typography alignment white base */
        --text-dim: #a0a0a0;
        --transition-smooth: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    }

    /* Strict Reset Engine preventing accidental horizontal window scrolling */
    * { 
        margin: 0; 
        padding: 0; 
        box-sizing: border-box; 
        -webkit-tap-highlight-color: transparent; 
    }
    
    body { 
        background-color: var(--bg-dark); 
        color: var(--white); 
        font-family: 'Plus Jakarta Sans', sans-serif; 
        overflow-x: hidden;
        line-height: 1.6;
        -webkit-font-smoothing: antialiased;
        -moz-osx-font-smoothing: grayscale;
    }

    /* Ambient Neon Glow Overlay (Optimized performance for mobile viewports) */
    body::before {
        content: ''; 
        position: fixed; 
        top: -10%; 
        left: -10%; 
        width: 100vw; 
        height: 100vh;
        background: radial-gradient(circle at 20% 20%, rgba(1, 200, 255, 0.05) 0%, transparent 50%); 
        z-index: -1; 
        pointer-events: none;
    }

    /* Fluid Responsive Grid Layout Container */
    .container { 
        width: 100%;
        max-width: 1200px; 
        margin: 0 auto; 
        padding: 0 clamp(16px, 4vw, 40px); /* Dynamic edge scaling prevents extreme squeezing on mobile */
        box-sizing: border-box;
    }

    /* Project Layout Core Glass Panels */
    .project-card { 
        background: var(--bg-card); 
        border: 1px solid var(--glass-border); 
        border-radius: 32px; 
        padding: clamp(20px, 5vw, 45px); 
        display: grid;
        grid-template-columns: 1.2fr 0.8fr; /* Desktop default side placement ratio */
        gap: clamp(24px, 4vw, 50px); 
        margin-bottom: 40px; 
        backdrop-filter: blur(15px); 
        -webkit-backdrop-filter: blur(15px);
        transition: var(--transition-smooth); 
        overflow: hidden;
        min-width: 0; /* Content internal bounding boxes locked */
        box-sizing: border-box;
    }

    @media (min-width: 992px) {
        .project-card:hover { 
            border-color: rgba(1, 200, 255, 0.35); 
            transform: translateY(-6px);
            background: rgba(255, 255, 255, 0.04);
            box-shadow: 0 25px 50px -12px rgba(0,0,0,0.5);
        }
    }

    /* Horizontal Gallery Handling Axis */
    .screenshot-gallery { 
        display: flex; 
        gap: 12px; 
        overflow-x: auto; 
        margin: 20px 0; 
        padding-bottom: 8px; 
        width: 100%;
        scrollbar-width: thin;
        scrollbar-color: var(--flutter-cyan) transparent;
        -webkit-overflow-scrolling: touch; 
    }

    /* Adaptive Mobile Phone Frame Scale */
    .phone-mockup { 
        width: 100%;
        max-width: 250px; 
        aspect-ratio: 9 / 19;
        height: auto;
        background: #000; 
        border: 10px solid #1e1e1e; 
        border-radius: 38px; 
        justify-self: center;
        position: relative; 
        overflow: hidden; 
        box-shadow: 0 20px 40px rgba(0,0,0,0.5); 
        margin: 0 auto;
    }

    /* Interactive Fluid Platform Buttons Matrix */
    .app-links { 
        display: flex; 
        gap: 12px; 
        margin-top: 25px; 
        flex-wrap: wrap; 
        width: 100%;
    }
    
    .app-btn { 
        flex: 1 1 130px; /* Automated grid-stretching based on horizontal width presence */
        min-width: 130px;
        justify-content: center;
        text-decoration: none; 
        color: var(--white); 
        background: rgba(255, 255, 255, 0.02); 
        border: 1px solid var(--glass-border); 
        padding: 12px 18px; 
        border-radius: 14px; 
        font-size: 0.85rem; 
        font-weight: 600;
        display: inline-flex; 
        align-items: center; 
        gap: 8px; 
        transition: var(--transition-smooth); 
        box-sizing: border-box;
    }
    
    .app-btn:hover {
        background: var(--flutter-cyan);
        color: #000;
        border-color: var(--flutter-cyan);
    }

    /* ULTRA-RESPONSIVE VIEWPORT BREAKPOINTS ENGINES */
    @media (max-width: 992px) {
        .project-card { 
            grid-template-columns: 1fr; /* Visual stack rotation */
            gap: 35px;
        }
        .hero-wrapper {
            grid-template-columns: 1fr;
            text-align: center;
        }
        .phone-mockup {
            order: -1; /* Puts real live mockups above text layers for mobile visibility dominance */
            max-width: 240px;
        }
    }

    @media (max-width: 600px) {
        h1 { font-size: clamp(2rem, 7vw, 2.5rem) !important; }
        .section-title { font-size: clamp(1.6rem, 6vw, 2rem) !important; }
        
        .project-card { 
            border-radius: 20px;
            padding: 16px;
        }

        .phone-mockup {
            max-width: 210px; /* Smooth down-scaling matching narrow device bounds */
        }

        .app-btn {
            width: 100%; 
            flex: none; /* Instant linear stacking on extreme phone scopes */
        }

        .hero-meta {
            flex-direction: column;
            gap: 12px;
            align-items: center;
        }
    }

    /* Fallback framework trigger for system transitions */
    .reveal.active {
        opacity: 1;
        transform: translateY(0);
    }

    /* Clean Dark Ambient Preservation during Prints */
    @media print {
        body { background: #040d16 !important; color: #fff !important; -webkit-print-color-adjust: exact !important; }
        .project-card { border: 1px solid #333 !important; background: rgba(255,255,255,0.02) !important; }
    }
</style>